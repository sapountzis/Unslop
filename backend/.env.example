# Database
DATABASE_URL=
DB_DRIVER=postgres

# App
APP_URL=http://localhost:3000

# Auth
JWT_SECRET=
MAGIC_LINK_SECRET=
MAGIC_LINK_BASE_URL=https://api.getunslop.com/v1/auth/callback

# Email
RESEND_API_KEY=
LOG_MAGIC_LINK_URLS=false

# Billing (Polar)
POLAR_ENV=sandbox
POLAR_API_KEY=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID=

# LLM (OpenRouter)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
# Required: text-only routing model
LLM_MODEL=
# Required: attachment-aware (image/PDF) routing model
VLM_MODEL=

# Quotas
FREE_MONTHLY_LLM_CALLS=300
PRO_MONTHLY_LLM_CALLS=10000
BATCH_LLM_CONCURRENCY=4

# Server
NODE_ENV=production
PORT=3000
