{
	"name": "unslop-backend",
	"version": "0.3.0",
	"scripts": {
		"dev": "bun run --env-file .env src/index.ts",
		"dev:workers": "wrangler dev",
		"start": "bun run --env-file .env src/index.ts",
		"deploy": "wrangler deploy",
		"check:fmt": "biome format --write .",
		"check:fmt:verify": "biome format --reporter=summary .",
		"check:lint": "biome lint --reporter=summary .",
		"check:type": "bunx tsgo --noEmit -p tsconfig.json",
		"test": "bun run test:unit",
		"test:unit": "rg --files src tests | rg '\\.test\\.ts$' | rg -v '\\.(integration|e2e)\\.test\\.ts$' | xargs -r bun test",
		"test:integration": "rg --files src tests | rg '\\.integration\\.test\\.ts$' | xargs -r bun test",
		"test:e2e": "rg --files src tests | rg '\\.e2e\\.test\\.ts$' | xargs -r bun test",
		"type-check": "bunx tsgo --noEmit -p tsconfig.json",
		"migrate": "drizzle-kit migrate",
		"migrate:generate": "drizzle-kit generate",
		"migrate:push": "bun run src/db/migrate.ts"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.4.0",
		"@polar-sh/hono": "^0.5.3",
		"async-retry": "^1.3.3",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^1.0.0-beta.15-859cf75",
		"hono": "^4.11.0",
		"openai": "^6.17.0",
		"pg": "^8.18.0",
		"resend": "^6.9.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "~2.3.15",
		"@cloudflare/workers-types": "^4.0.0",
		"@types/async-retry": "^1.4.9",
		"@types/node": "^22.0.0",
		"@types/pg": "^8.16.0",
		"@typescript/native-preview": "latest",
		"bun-types": "^1.2.2",
		"drizzle-kit": "^1.0.0-beta.15-859cf75",
		"typescript": "^5.9.0",
		"wrangler": "^4.0.0"
	}
}
