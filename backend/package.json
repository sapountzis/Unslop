{
  "name": "unslop-backend",
  "version": "0.1.0",
  "scripts": {
    "dev": "bun run --env-file .env src/index.ts",
    "dev:workers": "wrangler dev",
    "start": "bun run --env-file .env src/index.ts",
    "deploy": "wrangler deploy",
    "test": "bun run test:unit",
    "test:unit": "for f in $(rg --files src tests | rg '\\.test\\.ts$' | rg -v '\\.(integration|e2e)\\.test\\.ts$'); do bun test \"$f\" || exit 1; done",
    "test:integration": "for f in $(rg --files src tests | rg '\\.integration\\.test\\.ts$'); do bun test \"$f\" || exit 1; done",
    "test:e2e": "for f in $(rg --files src tests | rg '\\.e2e\\.test\\.ts$'); do bun test \"$f\" || exit 1; done",
    "type-check": "tsc --noEmit",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "@polar-sh/hono": "^0.5.3",
    "async-retry": "^1.3.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^1.0.0-beta.13-f728631",
    "hono": "^4.11.0",
    "openai": "^6.17.0",
    "postgres": "^3.4.8",
    "resend": "^6.9.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/async-retry": "^1.4.9",
    "@types/node": "^22.0.0",
    "bun-types": "^1.2.2",
    "drizzle-kit": "^1.0.0-beta.13-f728631",
    "typescript": "^5.9.0",
    "wrangler": "^4.0.0"
  }
}