{
	"name": "unslop-extension",
	"version": "0.4.4",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"check:fmt": "biome format --write .",
		"check:fmt:verify": "biome format --reporter=summary .",
		"check:lint": "biome lint --reporter=summary .",
		"check:type": "bunx tsgo --noEmit -p tsconfig.json",
		"build": "bunx tsgo --noEmit -p tsconfig.json && vite build",
		"preview": "vite preview",
		"test": "bun test src/"
	},
	"dependencies": {
		"@crxjs/vite-plugin": "^2.0.0-beta.23",
		"chart.js": "^4.5.1",
		"p-limit": "^7.3.0"
	},
	"devDependencies": {
		"@biomejs/biome": "~2.3.15",
		"@happy-dom/global-registrator": "^20.6.2",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/chrome": "^0.0.254",
		"@typescript/native-preview": "latest",
		"typescript": "^5.9.0",
		"vite": "^5.0.0"
	}
}
