---
interface Props {
  title: string;
  updated?: string;
}

const { title, updated } = Astro.props;
---

<main class="mx-auto min-h-screen max-w-4xl px-6 py-14 sm:px-10">
  <a href="/" class="font-mono text-xs uppercase tracking-[0.16em] text-graphite underline underline-offset-4">Back to home</a>
  <article class="mt-8 space-y-8">
    <header>
      <h1 class="text-4xl font-semibold sm:text-5xl">{title}</h1>
      {updated && <p class="mt-3 font-mono text-sm text-graphite">Last updated: {updated}</p>}
    </header>
    <div class="space-y-6 font-mono text-[15px] leading-relaxed text-ink/90">
      <slot />
    </div>
  </article>
</main>
