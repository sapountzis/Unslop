---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegalShell from '../components/LegalShell.astro';
---

<BaseLayout title="Privacy Policy | Unslop" description="How Unslop handles data.">
  <LegalShell title="Privacy Policy" updated="February 2026">
    <section class="space-y-3">
      <h2 class="font-serif text-2xl text-ink">Data we collect</h2>
      <p>Email for authentication, plus post content needed to classify feed items.</p>
      <p>
        Stored fields include post identifiers, author metadata, normalized content text, decision output, and
        timestamps.
      </p>
    </section>

    <section class="space-y-3">
      <h2 class="font-serif text-2xl text-ink">Why we collect it</h2>
      <p>To return keep/hide decisions, cache results, enforce quotas, and support reliability.</p>
      <p>No analytics, no ad targeting, no data resale.</p>
    </section>

    <section class="space-y-3">
      <h2 class="font-serif text-2xl text-ink">Processors</h2>
      <p>LLM inference provider, backend hosting provider, database provider, and payment processor.</p>
    </section>

    <section class="space-y-3">
      <h2 class="font-serif text-2xl text-ink">Retention</h2>
      <p>Posts: 90 days. Feedback: 180 days. Account records: until deletion request.</p>
      <p>
        Deletion requests: email <a class="underline" href="mailto:support@getunslop.com">support@getunslop.com</a>.
      </p>
    </section>
  </LegalShell>
</BaseLayout>
