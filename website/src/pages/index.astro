---
import BaseLayout from "../layouts/BaseLayout.astro";
import ToggleDemo from "../components/ToggleDemo.jsx";
import FadeIn from "../components/FadeIn.jsx";
import "fullpage.js/dist/fullpage.css";
---

<BaseLayout
  title="Unslop | Filter the feed"
  description="A free, open-source browser extension that filters AI-generated slop from LinkedIn, X, and Reddit. Bring your own key. No account, no subscription."
>
  <main id="fullpage">
    <section class="section text-center fp-noscroll">
      <div class="mx-auto max-w-4xl px-6">
        <FadeIn client:visible>
          <h1 class="text-5xl font-semibold leading-tight text-ink sm:text-7xl">
            The internet was built for connection.
          </h1>
        </FadeIn>
        <FadeIn client:visible delay={0.08}>
          <p
            class="mt-8 font-serif text-3xl font-light leading-[1.1] tracking-tight text-ink sm:text-4xl md:text-5xl"
          >
            Somewhere along the way, <br class="hidden md:block" />
            we became the <span class="font-normal italic">product</span>.
          </p>
        </FadeIn>
        <FadeIn client:visible delay={0.14}>
          <p
            class="mx-auto mt-8 max-w-2xl font-mono text-sm tracking-[0.02em] text-graphite sm:text-base"
          >
            Unslop is a free, open-source browser extension that filters
            AI-generated slop from your feed. Works on LinkedIn, X, and Reddit.
            Bring your own API key — no account, no subscription.
          </p>
        </FadeIn>
        <FadeIn client:visible delay={0.22}>
          <div
            class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
          >
            <a
              href="https://chromewebstore.google.com/detail/unslop/oichppihoiihcljjmpaaddflnkonbbbk"
              target="_blank"
              rel="noreferrer"
              class="group inline-flex items-center justify-center gap-3 border border-ink bg-ink px-6 py-3 font-mono text-sm uppercase tracking-[0.1em] text-paper transition-all hover:bg-paper hover:text-ink"
            >
              <span>Add to Chrome — It's Free</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="opacity-70 transition-opacity group-hover:opacity-100"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="4"></circle>
                <line x1="21.17" x2="12" y1="8" y2="8"></line>
                <line x1="3.95" x2="8.54" y1="6.06" y2="14"></line>
                <line x1="10.88" x2="15.46" y1="21.94" y2="14"></line>
              </svg>
            </a>

            <a
              href="https://buymeacoffee.com/unslop"
              target="_blank"
              rel="noreferrer"
              class="group inline-flex items-center justify-center gap-3 border border-ink px-6 py-3 font-mono text-xs uppercase tracking-[0.1em] text-ink transition-all hover:bg-ink hover:text-paper"
            >
              <span>Buy me a coffee</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="-mt-0.5 opacity-70 transition-opacity group-hover:opacity-100"
              >
                <path d="M17 8h1a4 4 0 1 1 0 8h-1"></path>
                <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"></path>
                <line x1="6" x2="6" y1="2" y2="4"></line>
                <line x1="10" x2="10" y1="2" y2="4"></line>
                <line x1="14" x2="14" y1="2" y2="4"></line>
              </svg>
            </a>
          </div>
        </FadeIn>
      </div>
    </section>

    <section class="section fp-noscroll">
      <div class="relative mx-auto w-full max-w-5xl">
        <div
          aria-hidden="true"
          class="pointer-events-none absolute -top-8 left-0 right-0 hidden select-none font-mono text-xs leading-6 text-ink/[0.06] sm:block"
        >
          <p>
            zx01 // ctr ↑ // bait // 0034 // mine attention // loop // loop //
            loop //
          </p>
          <p>
            engagement++ // outrage // novelty // ad_slot //
            optimize_time_on_platform //
          </p>
          <p>
            predictive_feed // harvest_focus // rage_cycle // monetization //
            retention //
          </p>
        </div>
        <div class="max-w-2xl px-6">
          <FadeIn client:visible>
            <h2 class="text-4xl font-semibold leading-tight sm:text-6xl">
              The feed is not your friend.
            </h2>
          </FadeIn>
          <FadeIn client:visible delay={0.1}>
            <p
              class="mt-8 font-mono text-base leading-relaxed text-graphite sm:text-lg"
            >
              Every platform optimises for time-on-site, not signal quality.
              The result is feeds packed with AI-generated filler, engagement
              bait, and manufactured outrage — with the actual human content
              buried underneath. Unslop runs each post through a scoring rubric
              and quietly removes what doesn't make the cut.
            </p>
          </FadeIn>
        </div>
      </div>
    </section>

    <section class="section long-content">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <FadeIn client:visible>
          <h2 class="mb-8 text-4xl font-semibold sm:text-5xl">
            Experience the silence.
          </h2>
        </FadeIn>
        <ToggleDemo client:visible />
      </div>
    </section>

    <section class="section fp-noscroll">
      <div
        class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-14 px-6 md:grid-cols-2 md:gap-20"
      >
        <FadeIn client:visible>
          <div>
            <h2 class="text-4xl font-semibold sm:text-5xl">
              Runs entirely in your browser.
            </h2>
            <p class="mt-8 font-mono text-base leading-relaxed text-graphite">
              Bring your own API key — OpenAI, Anthropic, OpenRouter, or any
              OpenAI-compatible endpoint, including a local Ollama instance.
            </p>
            <p class="mt-5 font-mono text-base leading-relaxed text-graphite">
              The model reads each post and returns a direct keep or hide
              decision. Nothing touches any external server except the LLM calls
              you configure. Your key stays in <code class="text-ink">chrome.storage.local</code>.
            </p>
          </div>
        </FadeIn>
        <FadeIn client:visible delay={0.1}>
          <div class="border border-ink/25 bg-[#efede6] p-6 sm:p-8">
            <p class="font-mono text-sm leading-8 text-ink">
              &gt; post arrives in feed<br />
              &gt; classifier (your key)<br />
              &gt; decision: HIDE<br />
              &gt; status: COLLAPSED
            </p>
          </div>
        </FadeIn>
      </div>
    </section>

    <section class="section fp-noscroll">
      <div
        class="mx-auto flex w-full max-w-6xl flex-col justify-between gap-14 px-6"
      >
        <div class="mx-auto max-w-2xl text-center">
          <FadeIn client:visible>
            <h2 class="text-4xl font-semibold sm:text-5xl">
              Free and open source.
            </h2>
          </FadeIn>
          <FadeIn client:visible delay={0.08}>
            <p class="mt-8 font-mono text-base leading-relaxed text-graphite">
              No account. No subscription. No data collected. Install the
              extension, add your API key, and own your feed.
            </p>
            <p class="mt-4 font-mono text-sm leading-relaxed text-graphite">
              If you find it useful, a coffee keeps the project alive.
            </p>
          </FadeIn>
          <FadeIn client:visible delay={0.16}>
            <div
              class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
            >
              <a
                href="https://chromewebstore.google.com/detail/unslop/oichppihoiihcljjmpaaddflnkonbbbk"
                target="_blank"
                rel="noreferrer"
                class="group inline-flex items-center justify-center gap-3 border border-ink bg-ink px-6 py-3 font-mono text-sm uppercase tracking-[0.1em] text-paper transition-all hover:bg-paper hover:text-ink"
              >
                <span>Add to Chrome</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="opacity-70 transition-opacity group-hover:opacity-100"
                >
                  <circle cx="12" cy="12" r="10"></circle>
                  <circle cx="12" cy="12" r="4"></circle>
                  <line x1="21.17" x2="12" y1="8" y2="8"></line>
                  <line x1="3.95" x2="8.54" y1="6.06" y2="14"></line>
                  <line x1="10.88" x2="15.46" y1="21.94" y2="14"></line>
                </svg>
              </a>

              <a
                href="https://buymeacoffee.com/unslop"
                target="_blank"
                rel="noreferrer"
                class="group inline-flex items-center justify-center gap-3 border border-ink px-6 py-3 font-mono text-xs uppercase tracking-[0.1em] text-ink transition-all hover:bg-ink hover:text-paper"
              >
                <span>Buy me a coffee</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="-mt-0.5 opacity-70 transition-opacity group-hover:opacity-100"
                >
                  <path d="M17 8h1a4 4 0 1 1 0 8h-1"></path>
                  <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"></path>
                  <line x1="6" x2="6" y1="2" y2="4"></line>
                  <line x1="10" x2="10" y1="2" y2="4"></line>
                  <line x1="14" x2="14" y1="2" y2="4"></line>
                </svg>
              </a>
            </div>
          </FadeIn>
        </div>

        <footer class="pb-4 text-center">
          <p
            class="font-mono text-xs uppercase tracking-[0.14em] text-graphite"
          >
            Built by a human.
          </p>
          <p
            class="mt-3 font-mono text-xs uppercase tracking-[0.14em] text-graphite"
          >
            <a
              href="https://github.com/sapountzis/Unslop/issues"
              target="_blank"
              rel="noreferrer"
              class="underline underline-offset-4">GitHub</a
            >
            •
            <a
              href="https://buymeacoffee.com/unslop"
              target="_blank"
              rel="noreferrer"
              class="underline underline-offset-4">Buy me a coffee</a
            >
          </p>
        </footer>
      </div>
    </section>
  </main>

  <script>
    import fullpage from "fullpage.js";

    new fullpage("#fullpage", {
      // Navigation
      navigation: false,
      navigationPosition: "right",

      // Scrolling
      css3: true,
      scrollingSpeed: 700,
      autoScrolling: true,
      fitToSection: true,
      fitToSectionDelay: 600,
      scrollBar: false,
      easing: "easeInOutCubic",
      easingcss3: "cubic-bezier(0.42, 0, 0.58, 1)",
      loopBottom: false,
      loopTop: false,

      // Accessibility
      keyboardScrolling: true,
      animateAnchor: true,
      recordHistory: true,

      // Design
      verticalCentered: true,
      sectionSelector: ".section",
      responsiveWidth: 768,

      // Overflow Handling
      scrollOverflow: true,

      // Touch sensitivity
      touchSensitivity: 15,

      bigSectionsDestination: "top",
    });
  </script>
</BaseLayout>
