---
import BaseLayout from "../layouts/BaseLayout.astro";
import ToggleDemo from "../components/ToggleDemo.jsx";
import FadeIn from "../components/FadeIn.jsx";
import "fullpage.js/dist/fullpage.css";
---

<BaseLayout
  title="Unslop | Filter the feed"
  description="A free, open-source browser extension that filters AI-generated slop from LinkedIn, X, and Reddit. Bring your own key. No account, no subscription."
>
  <main id="fullpage">
    <!-- Section 1: Hero -->
    <section class="section text-center fp-noscroll">
      <div class="mx-auto max-w-4xl px-6">
        <FadeIn client:visible>
          <h1 class="text-5xl font-semibold leading-tight text-ink sm:text-7xl">
            Unslop
          </h1>
        </FadeIn>
        <FadeIn client:visible delay={0.08}>
          <p
            class="mt-6 font-serif text-3xl font-light leading-[1.1] tracking-tight text-ink sm:text-4xl"
          >
            Filter the slop from your feed.
          </p>
        </FadeIn>
        <FadeIn client:visible delay={0.14}>
          <p
            class="mx-auto mt-8 max-w-2xl font-mono text-sm tracking-[0.02em] text-graphite sm:text-base"
          >
            Open-source Chrome extension that uses AI to detect and hide
            low-quality posts on LinkedIn, X, and Reddit. Bring your own
            API key. No account needed.
          </p>
        </FadeIn>
        <FadeIn client:visible delay={0.20}>
          <div
            class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
          >
            <a
              href="https://chromewebstore.google.com/detail/unslop/oichppihoiihcljjmpaaddflnkonbbbk"
              target="_blank"
              rel="noreferrer"
              class="group inline-flex items-center justify-center gap-3 border border-ink bg-ink px-6 py-3 font-mono text-sm uppercase tracking-[0.1em] text-paper transition-all hover:bg-paper hover:text-ink"
            >
              <span>Add to Chrome — It's Free</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="opacity-70 transition-opacity group-hover:opacity-100"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="4"></circle>
                <line x1="21.17" x2="12" y1="8" y2="8"></line>
                <line x1="3.95" x2="8.54" y1="6.06" y2="14"></line>
                <line x1="10.88" x2="15.46" y1="21.94" y2="14"></line>
              </svg>
            </a>

            <a
              href="https://github.com/sapountzis/Unslop"
              target="_blank"
              rel="noreferrer"
              class="group inline-flex items-center justify-center gap-3 border border-ink px-6 py-3 font-mono text-xs uppercase tracking-[0.1em] text-ink transition-all hover:bg-ink hover:text-paper"
            >
              <span>GitHub</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="opacity-70 transition-opacity group-hover:opacity-100"
              >
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                <path d="M9 18c-4.51 2-5-2-7-2"></path>
              </svg>
            </a>
          </div>
        </FadeIn>
        <FadeIn client:visible delay={0.26}>
          <p
            class="mx-auto mt-8 max-w-xl font-mono text-xs tracking-[0.02em] text-graphite/60"
          >
            Works with OpenAI · Anthropic · OpenRouter · Ollama · any OpenAI-compatible endpoint
          </p>
        </FadeIn>
      </div>
    </section>

    <!-- Section 2: Demo -->
    <section class="section long-content">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <FadeIn client:visible>
          <h2 class="mb-8 text-4xl font-semibold sm:text-5xl">
            Before and after.
          </h2>
        </FadeIn>
        <ToggleDemo client:visible />
      </div>
    </section>

    <!-- Section 3: How it works + Trust -->
    <section class="section fp-noscroll">
      <div
        class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-14 px-6 md:grid-cols-2 md:gap-20"
      >
        <FadeIn client:visible>
          <div>
            <h2 class="text-4xl font-semibold sm:text-5xl">
              Your key. Your browser. Nothing else.
            </h2>
            <p class="mt-8 font-mono text-base leading-relaxed text-graphite">
              Each post gets classified by the model you choose. The only
              network requests are the API calls you configure. Your key
              stays in local storage. No backend, no account, no telemetry.
            </p>
          </div>
        </FadeIn>
        <FadeIn client:visible delay={0.1}>
          <div class="border border-ink/25 bg-[#efede6] p-6 sm:p-8">
            <p class="font-mono text-sm leading-8 text-ink">
              &gt; post arrives in feed<br />
              &gt; send to model (your key)<br />
              &gt; verdict: HIDE<br />
              &gt; post collapsed
            </p>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- Section 4: Closing -->
    <section class="section fp-noscroll">
      <div
        class="mx-auto flex w-full max-w-4xl flex-col items-center justify-center gap-10 px-6 text-center"
      >
        <FadeIn client:visible>
          <h2 class="text-4xl font-semibold sm:text-5xl">
            Start filtering.
          </h2>
        </FadeIn>
        <FadeIn client:visible delay={0.06}>
          <p class="font-mono text-base leading-relaxed text-graphite">
            Install the extension. Add your API key. That's it.
          </p>
        </FadeIn>
        <FadeIn client:visible delay={0.12}>
          <a
            href="https://chromewebstore.google.com/detail/unslop/oichppihoiihcljjmpaaddflnkonbbbk"
            target="_blank"
            rel="noreferrer"
            class="group inline-flex items-center justify-center gap-3 border border-ink bg-ink px-6 py-3 font-mono text-sm uppercase tracking-[0.1em] text-paper transition-all hover:bg-paper hover:text-ink"
          >
            <span>Add to Chrome</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="opacity-70 transition-opacity group-hover:opacity-100"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <circle cx="12" cy="12" r="4"></circle>
              <line x1="21.17" x2="12" y1="8" y2="8"></line>
              <line x1="3.95" x2="8.54" y1="6.06" y2="14"></line>
              <line x1="10.88" x2="15.46" y1="21.94" y2="14"></line>
            </svg>
          </a>
        </FadeIn>

        <footer class="pt-6 pb-4">
          <p
            class="font-mono text-xs uppercase tracking-[0.14em] text-graphite"
          >
            Built by a human.
          </p>
          <p
            class="mt-3 font-mono text-xs uppercase tracking-[0.14em] text-graphite"
          >
            <a
              href="https://github.com/sapountzis/Unslop"
              target="_blank"
              rel="noreferrer"
              class="underline underline-offset-4">GitHub</a
            >
            •
            <a
              href="https://buymeacoffee.com/unslop"
              target="_blank"
              rel="noreferrer"
              class="underline underline-offset-4">Buy me a coffee</a
            >
          </p>
        </footer>
      </div>
    </section>
  </main>

  <script>
    import fullpage from "fullpage.js";

    new fullpage("#fullpage", {
      afterRender() {
        document.getElementById("fullpage")?.classList.add("fullpage-initialized");
      },

      // Navigation
      navigation: false,
      navigationPosition: "right",

      // Scrolling
      css3: true,
      scrollingSpeed: 700,
      autoScrolling: true,
      fitToSection: true,
      fitToSectionDelay: 600,
      scrollBar: false,
      easing: "easeInOutCubic",
      easingcss3: "cubic-bezier(0.42, 0, 0.58, 1)",
      loopBottom: false,
      loopTop: false,

      // Accessibility
      keyboardScrolling: true,
      animateAnchor: true,
      recordHistory: true,

      // Design
      verticalCentered: true,
      sectionSelector: ".section",
      responsiveWidth: 768,

      // Overflow Handling
      scrollOverflow: true,

      // Touch sensitivity
      touchSensitivity: 15,

      bigSectionsDestination: "top",
    });
  </script>
</BaseLayout>
