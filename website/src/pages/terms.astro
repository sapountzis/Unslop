---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalShell from "../components/LegalShell.astro";
---

<BaseLayout title="Terms | Unslop" description="Terms for Unslop.">
  <LegalShell title="Terms">
    <section class="space-y-3">
      <p>
        Unslop is free, open-source software. Use it however you like.
        The software is provided as-is, without warranties of any kind.
      </p>
      <p>
        <a class="underline" href="https://github.com/sapountzis/Unslop/issues" target="_blank" rel="noreferrer">GitHub issues</a> for anything else.
      </p>
    </section>
  </LegalShell>
</BaseLayout>
